PYTHON = config.get("python", "python3")


rule all:
    input:
        "data/metadata/gse131907_cell_metadata_clean.csv",
        "docs/tables/cell_counts_by_sample.csv",
        "docs/tables/celltype_composition_by_sample.csv",
        "docs/tables/tissue_site_summary.csv",
        "docs/tables/planned_tme_signatures.csv",
        "docs/figures/sample_counts_by_tissue.png",
        "docs/figures/celltype_composition_by_sample.png",
        "docs/figures/top_celltypes_by_site.png",


rule full:
    input:
        "docs/tables/key_results_summary.csv",
        "docs/figures/signature_contrast_effect_sizes.png",
        "docs/figures/paired_patient_signature_deltas.png",
        "docs/figures/top_subtypes_by_tissue.png",


rule download_annotation:
    output:
        "data/raw_geo/GSE131907_Lung_Cancer_cell_annotation.txt.gz",
    shell:
        "{PYTHON} scripts/00_download_geo.py --annotation-only"


rule download_raw_umi:
    output:
        "data/raw_geo/GSE131907_Lung_Cancer_raw_UMI_matrix.txt.gz",
        "data/raw_geo/GSE131907_Lung_Cancer_Feature_Summary.xlsx",
    shell:
        "{PYTHON} scripts/00_download_geo.py --raw-only"


rule metadata:
    input:
        "data/raw_geo/GSE131907_Lung_Cancer_cell_annotation.txt.gz",
    output:
        "data/metadata/gse131907_cell_metadata_clean.csv",
    shell:
        "{PYTHON} scripts/01_metadata_overview.py"


rule composition:
    input:
        "data/metadata/gse131907_cell_metadata_clean.csv",
